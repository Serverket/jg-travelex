# Supabase (Frontend)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase (Backend / Express on Render)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Google Maps JS SDK (browser-side map rendering + Places Autocomplete)
# Restrict to your domain referrers in Google Cloud Console before deploying.
VITE_NSA_REGISTRY=your_google_maps_api_key

# EIA API (free fuel prices — optional, falls back to manual price)
VITE_CIE_FU=your_eia_api_key

# Express Backend on Render
PORT=8000
CORS_ORIGIN=http://localhost:5173
VITE_BACKEND_URL=http://localhost:8000

# Local Supabase CLI (dev only — leave commented for production)
#VITE_SUPABASE_FUNCTIONS_URL=http://127.0.0.1:54321
#VITE_SUPABASE_LOCAL_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: login background slideshow images
#VITE_LOGIN_BG_IMAGES=/destinations/image1.webp,/destinations/image2.webp
